# Generic edition. It never loads a private project content pack unless explicitly configured.
CREATOR_EDITION=generic
CREATOR_SOURCE_ROOT=content-packs/creator-generic/source
CREATOR_DATABASE_PATH=data/creator-agent.sqlite
CREATOR_OUTPUT_ROOT=output

HOST=0.0.0.0
PORT=8787
ADMIN_TOKEN=

# Text model. OpenAI-compatible endpoints are supported.
LLM_PROVIDER=openai
LLM_API_MODE=auto
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=
LLM_API_KEY=
LLM_TIMEOUT_MS=120000

# Optional direct API image route. Codex native image_gen is the default when available.
IMAGE_PROVIDER=openai
IMAGE_MODEL=gpt-image-2
IMAGE_BASE_URL=https://api.openai.com/v1
IMAGE_API_KEY=
OPENAI_IMAGE_SIZE=1024x1536
OPENAI_IMAGE_QUALITY=medium
OPENAI_IMAGE_FORMAT=png
OPENAI_IMAGE_TIMEOUT_MS=180000

# Optional local fallback only.
COMFYUI_ENABLED=0
COMFYUI_BASE_URL=http://127.0.0.1:8188