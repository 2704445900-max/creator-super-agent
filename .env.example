# Optional. Leave empty to use evidence-only mode.
LLM_PROVIDER=openai
LLM_API_MODE=auto
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=
LLM_API_KEY=
LLM_TIMEOUT_MS=120000

# Optional. If set, /api/sync requires this token in X-Admin-Token.
ADMIN_TOKEN=

# Optional server override.
HOST=0.0.0.0
PORT=8787

# Distribution mode: combined keeps Xinrui + generic workspaces; generic disables
# Xinrui seed data and forces all creative requests into creator-generic.
CREATOR_EDITION=combined
CREATOR_SOURCE_ROOT=
CREATOR_DATABASE_PATH=
CREATOR_OUTPUT_ROOT=

# Test isolation. Leave these empty in normal production use.
# npm run test:pipeline sets them automatically for its database snapshot and output sandbox.
XINRUI_SOURCE_ROOT=
XINRUI_DATABASE_PATH=
XINRUI_OUTPUT_ROOT=
XINRUI_TEST_MODE=0

# Optional daily Xiaohongshu image generation.
# The daily:xhs script sends prompts directly to /images/generations.
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_API_BASE=https://api.openai.com/v1
OPENAI_IMAGE_SIZE=1024x1536
OPENAI_IMAGE_QUALITY=medium
OPENAI_IMAGE_FORMAT=png
OPENAI_IMAGE_TIMEOUT_MS=180000

# Primary image execution backend. Prefer ChatGPT/OpenAI gpt-image-2 or a
# configured OpenAI-compatible cloud multimodal image model. Paid execution
# only occurs after an explicit agent approval or execute/generate request.
IMAGE_PROVIDER=openai
IMAGE_MODEL=gpt-image-2
IMAGE_BASE_URL=https://api.openai.com/v1
IMAGE_API_KEY=

# Optional local fallback only. It is not required for the default workflow.
COMFYUI_ENABLED=0
COMFYUI_BASE_URL=http://127.0.0.1:8188
COMFYUI_IMG2IMG_WORKFLOW=config\comfyui\xinrui-img2img-sdxl-workflow_api.json
COMFYUI_OUTPUT_NODE_ID=9
COMFYUI_CHECKPOINT=sd_xl_base_1.0.safetensors
COMFYUI_STEPS=24
COMFYUI_CFG=6.5
COMFYUI_DENOISE=0.58
COMFYUI_SAMPLER=dpmpp_2m_sde
COMFYUI_SCHEDULER=karras
COMFYUI_POLL_MS=1500
COMFYUI_TIMEOUT_MS=300000
